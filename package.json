{
  "name": "embetty-vue",
  "version": "2.0.1",
  "description": "Embetty displays remote content like tweets or videos without compromising your privacy.",
  "license": "MIT",
  "author": {
    "name": "Florian Edelmann",
    "email": "git@flo-edelmann.de"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FloEdelmann/embetty-vue"
  },
  "bugs": {
    "url": "https://github.com/FloEdelmann/embetty-vue/issues"
  },
  "keywords": [
    "vue",
    "vuejs",
    "embetty",
    "privacy",
    "youtube",
    "vimeo",
    "facebook",
    "twitter",
    "video"
  ],
  "main": "./dist/embetty-vue.cjs",
  "module": "./dist/embetty-vue.mjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:lib && npm run build:browser-dev && npm run build:browser-prod",
    "build:lib": "vite build",
    "build:browser-dev": "vite build --config vite.browser.config.js --mode development",
    "build:browser-prod": "vite build --config vite.browser.config.js",
    "lint": "eslint",
    "version": "npm run build && git add -A dist"
  },
  "peerDependencies": {
    "vue": "^2.7.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.0",
    "@vitejs/plugin-vue2": "^2.3.4",
    "clean-css": "^5.0.1",
    "eslint": "^10.0.0",
    "eslint-plugin-no-es2015": "^1.2.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "sass": "^1.97.3",
    "vite": "^7.3.1",
    "vue": "^2.7.0",
    "vue-eslint-parser": "^10.4.0"
  }
}
